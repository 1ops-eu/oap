# OAP API Server Configuration
# Copy to .env for local development

# Database
DATABASE_URL=postgres://oap:oap@localhost:5432/oap

# Server
OAP_HOST=0.0.0.0
OAP_PORT=8080

# Logging
RUST_LOG=oap_api=debug,oap_domain=debug,oap_db=debug,oap_events=debug,tower_http=debug

# Webhook signing secret (HMAC-SHA256)
OAP_WEBHOOK_SECRET=dev-secret-change-in-production
